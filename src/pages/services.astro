---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/TopNav.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import { business } from '../data/business.ts';
---

<BaseLayout title="Services" page="services">
  <TopNav slot="topnav" />

  <Hero
    heading="Services"
    subhead={`What ${business.name} does for ${business.address.city}.`}
    showCta={false}
    height="min-h-[50vh]"
  />

  <section class="section-padding">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {business.services.map((service, i) => (
          <ServiceCard
            name={service.name}
            description={service.description}
            image={business.photos.gallery[i % business.photos.gallery.length]}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: business.services.slice(0, 5).map((s) => ({
      '@type': 'Question',
      name: `What does ${s.name.toLowerCase()} include?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: s.description,
      },
    })),
  })} />

  <!-- CTA -->
  <section class="py-20 bg-[var(--accent)]">
    <div class="container-main text-center">
      <h2 class="font-['Instrument_Serif',serif] italic text-[clamp(1.75rem,3.5vw,2.75rem)] text-white mb-6 scroll-reveal">
        Need a quote?
      </h2>
      <a href={`tel:${business.phone}`} class="btn-primary bg-white text-[var(--accent)] text-lg scroll-reveal">
        Call {business.phone}
      </a>
    </div>
  </section>

  <Footer slot="footer" />
  <MobileCallBar slot="mobile-call-bar" />
</BaseLayout>
