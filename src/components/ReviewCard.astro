---
interface Props {
  name: string;
  city: string;
  rating: number;
  text: string;
  featured?: boolean;
}

const { name, city, rating, text, featured = false } = Astro.props;
---

<div class:list={["scroll-reveal", featured ? "col-span-full" : ""]}>
  <div class:list={["bg-[var(--bg-elevated)] rounded-2xl p-8 border border-[var(--border)]", featured && "md:flex md:items-center md:gap-12"]}>
    <div class:list={[featured && "md:flex-1"]}>
      <div class="flex gap-1 mb-4">
        {Array.from({ length: rating }).map(() => (
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--accent)" stroke="none">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        ))}
      </div>
      {featured ? (
        <blockquote class="font-['Instrument_Serif',serif] italic text-2xl md:text-3xl leading-snug text-[var(--ink)] mb-6">
          "{text}"
        </blockquote>
      ) : (
        <p class="text-[var(--ink-2)] leading-relaxed mb-6">"{text}"</p>
      )}
      <div class="flex items-center gap-2 text-sm">
        <span class="font-bold text-[var(--ink)]">{name}</span>
        <span class="text-[var(--ink-3)]">·</span>
        <span class="text-[var(--ink-3)]">{city}</span>
      </div>
    </div>
  </div>
</div>
