---
const { business } = await import('../data/business.ts');
const mapsUrl = business.address.googleMapsUrl;
---

<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden" style="background: var(--accent);">
  <div class="flex h-16">
    <a href={`tel:${business.phone}`} class="flex-1 flex items-center justify-center text-white font-bold text-base gap-2 min-h-[48px]">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
      Call {business.phone}
    </a>
    <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center text-white font-bold text-base gap-2 min-h-[48px] border-l border-white/20">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" />
      </svg>
      Directions
    </a>
  </div>
</div>

<style>
  body {
    padding-bottom: 64px;
  }
  @media (min-width: 769px) {
    body {
      padding-bottom: 0;
    }
  }
</style>
