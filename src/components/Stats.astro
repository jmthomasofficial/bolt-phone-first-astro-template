---
const { business } = await import('../data/business.ts');
---

<section class="py-12 border-y border-[var(--border)] bg-[var(--bg-elevated)]">
  <div class="container-main">
    <div class="grid grid-cols-3 gap-8 text-center">
      {business.stats.map((stat) => (
        <div class="scroll-reveal">
          <div class="font-['Instrument_Serif',serif] text-[clamp(2rem,4vw,3.5rem)] text-[var(--accent)] leading-none mb-2">{stat.number}</div>
          <div class="text-sm text-[var(--ink-3)] uppercase tracking-widest">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
