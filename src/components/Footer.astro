---
const { business } = await import('../data/business.ts');
---

<footer class="bg-[var(--ink)] text-white/70 py-16">
  <div class="container-main">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <h3 class="font-['Instrument_Serif',serif] text-white text-2xl mb-4">{business.name}</h3>
        <p class="text-sm leading-relaxed">{business.description}</p>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Contact</h4>
        <a href={`tel:${business.phone}`} class="block text-lg text-white mb-2 hover:text-[var(--accent)] transition-colors">{business.phone}</a>
        <p class="text-sm">{business.address.street}</p>
        <p class="text-sm">{business.address.city}, {business.address.state} {business.address.zip}</p>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Hours</h4>
        <div class="space-y-1 text-sm">
          {business.hours.map((h) => (
            <div class="flex justify-between">
              <span>{h.day}</span>
              <span class:text-white={h.open !== 'Closed'}>{h.open === 'Closed' ? 'Closed' : `${h.open} – ${h.close}`}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 text-center text-xs">
      <p>&copy; {new Date().getFullYear()} {business.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
